<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<groupId>net.myerichsen.gedcomAnalyzer</groupId>
	<artifactId>ParentsOutsideParish</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>ParentsOutsideParish</name>
	<properties>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<maven.compiler.source>17</maven.compiler.source>
		<maven.compiler.target>17</maven.compiler.target>
	</properties>
	<description>Find common parents from census records outside the parish in a
		GEDCOM</description>
	<dependencies>
		<!-- Source: https://mvnrepository.com/artifact/org.gedcom4j/gedcom4j -->
		<dependency>
			<groupId>org.gedcom4j</groupId>
			<artifactId>gedcom4j</artifactId>
			<version>4.0.1</version>
			<scope>compile</scope>
		</dependency>
	</dependencies>
</project>